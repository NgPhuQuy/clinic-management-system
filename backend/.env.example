# Django
SECRET_KEY=your-very-secret-key-at-least-50-chars-long
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database MySQL
DB_NAME=clinic_db
DB_USER=root
DB_PASSWORD=yourpassword

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081

# Firebase Admin SDK
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# OAuth2 client
CLIENT_ID=your_oauth2_client_id
CLIENT_SECRET=your_oauth2_client_secret

# URL backend (thay bằng IP thật khi test với thiết bị thật)
BACKEND_BASE_URL=http://192.168.1.x:8000

