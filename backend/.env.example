# ─────────────────────────────────────────────
# .env.example — copy thành .env và điền giá trị thật
# cp .env.example .env
# ─────────────────────────────────────────────

# Django
SECRET_KEY=your-very-secret-key-at-least-50-chars-long
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database MySQL
DB_NAME=clinic_db
DB_USER=root
DB_PASSWORD=yourpassword


# JWT Token lifetime
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Cloudinary (lưu ảnh avatar)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS (production — phân cách bằng dấu phẩy)
CORS_ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081

