# ─────────────────────────────────────────────
# .env.example — copy thành .env và điền giá trị thật
# cp .env.example .env
# ─────────────────────────────────────────────

# Django
SECRET_KEY=your-very-secret-key-at-least-50-chars-long
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database MySQL
DB_NAME=clinic_db
DB_USER=root
DB_PASSWORD=yourpassword

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081

# ─────────────────────────────────────────────
# Firebase Admin SDK
# ─────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ─────────────────────────────────────────────
# OAuth2 — Swagger UI client
# ─────────────────────────────────────────────
SWAGGER_CLIENT_ID=your_oauth2_client_id
SWAGGER_CLIENT_SECRET=your_oauth2_client_secret
